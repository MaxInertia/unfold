# Build outputs
/unfold
/unfold-*
/dist/
/web/dist/
/web/node_modules/
node_modules/
bun.lock

# Embedded frontend build artifacts (placeholder index.html is checked in)
/internal/server/static/dist/*
!/internal/server/static/dist/index.html

# TS incremental build cache
*.tsbuildinfo

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Stray top-level package.json from one-off bun installs (frontend deps live in /web/)
/package.json

# Plugin signing material — must never be committed (kept here too in case keys
# are generated at the repo root rather than under goland-plugin/)
*.pem
chain.crt
*.p12
*.key
publish-token*
